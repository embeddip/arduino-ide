# ============================================================================
# .gitignore for embedDIP Library
# Portable Embedded Digital Image Processing Library
# ============================================================================

# ====================
# Build Artifacts
# ====================
build/
build-*/
Build/
out/
bin/
obj/
.cache/
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.elf
*.bin
*.hex
*.map
*.lst
*.lss
*.sym
*.d

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
!CMakeLists.txt
compile_commands.json
.ninja_deps
.ninja_log

# ====================
# IDE Files
# ====================

# VSCode
.vscode/
*.code-workspace

# CLion / IntelliJ
.idea/
cmake-build-*/

# Eclipse
.cproject
.project
.settings/

# Vim
*.swp
*.swo
*~
.*.sw?

# Emacs
\#*\#
.\#*

# ====================
# OS Files
# ====================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ====================
# Testing & Coverage
# ====================
Testing/
CTestTestfile.cmake
*.gcov
*.gcda
*.gcno
*.gcno
coverage.info
coverage.out
coverage-report/
htmlcov/
.coverage
.pytest_cache/

# ====================
# Documentation
# ====================
docs/html/
docs/latex/
docs/xml/
docs/_build/
docs/.doctrees/
Doxyfile.bak
*.pdf
!docs/*.pdf

# ====================
# Python (for scripts)
# ====================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.eggs/
venv/
env/
ENV/

# ====================
# Node.js (for tools)
# ====================
node_modules/
npm-debug.log
yarn-error.log

# ====================
# Logs & Temporary
# ====================
*.log
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
.log

# ====================
# Archives
# ====================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
