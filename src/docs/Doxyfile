OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = core imgproc board device wrapper embedDIP.h embedDIP.hpp embedDIP_configs.h
FILE_PATTERNS          = *.c *.cpp *.h *.hpp
